# Copy to .env and adjust as needed.
# These values are consumed by docker-compose.yml.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=bugtracker
MYSQL_USER=mantis
MYSQL_PASSWORD=mantis
MYSQL_PORT=3306

# --- Caddy ---
# Change if port 80 is taken on the host (e.g. 8080).
CADDY_HTTP_PORT=80

# --- Mantis ---
# Must be at least 16 chars. Generate with: openssl rand -hex 32
MANTIS_CRYPTO_SALT=dev-only-change-me-1234567890abcdef
